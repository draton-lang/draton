{
  "name": "draton",
  "publisher": "draton-local",
  "displayName": "Draton",
  "description": "Draton language support",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:draton"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "draton",
        "aliases": [
          "Draton",
          "draton"
        ],
        "extensions": [
          ".dt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "draton",
        "scopeName": "source.draton",
        "path": "./syntaxes/draton.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Draton Prism Night",
        "uiTheme": "vs-dark",
        "path": "./themes/draton-prism-night-color-theme.json"
      }
    ],
    "configuration": {
      "title": "Draton",
      "properties": {
        "draton.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Duong dan toi binary `drat` hoac `draton-lsp`. Neu bo trong, extension se tu thu cac binary trong workspace `target/` roi moi fallback ve PATH."
        },
        "draton.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Danh sach tham so bo sung truyen vao Draton language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  }
}
