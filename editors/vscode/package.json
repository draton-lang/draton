{
  "name": "draton",
  "publisher": "draton",
  "displayName": "Draton",
  "description": "Syntax highlighting, LSP diagnostics, and the Draton Prism Night theme for the Draton programming language.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/draton-lang/draton",
  "repository": {
    "type": "git",
    "url": "https://github.com/draton-lang/draton.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/draton-lang/draton/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "draton",
    "drat",
    "language",
    "compiled",
    "llvm"
  ],
  "activationEvents": [
    "onLanguage:draton"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "draton",
        "aliases": [
          "Draton",
          "draton"
        ],
        "extensions": [
          ".dt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "draton",
        "scopeName": "source.draton",
        "path": "./syntaxes/draton.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Draton Prism Night",
        "uiTheme": "vs-dark",
        "path": "./themes/draton-prism-night-color-theme.json"
      }
    ],
    "configuration": {
      "title": "Draton",
      "properties": {
        "draton.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `drat` or `draton-lsp` binary. When empty the extension resolves binaries from the workspace `target/` directory, then falls back to `PATH`."
        },
        "draton.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Additional arguments passed to the Draton language server on startup."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  }
}
