fn make_field_member(field) {
    return ClassMember { kind: MemberField, field: Some(field), method: None, layer_def: None }
}

fn make_method_member(method) {
    return ClassMember { kind: Method, field: None, method: Some(method), layer_def: None }
}

fn make_layer_member(layer_def) {
    return ClassMember { kind: Layer, field: None, method: None, layer_def: Some(layer_def) }
}
