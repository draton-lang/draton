    return json_object([
        json_field("module", json_string_array(import_def.module)),
        json_field("items", serialize_typed_import_items(import_def.items)),
        json_field("span", serialize_span(import_def.span))
    ])
}

fn serialize_typed_import_items(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_import_item(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_import_item(item) {
    return json_object([
        json_field("name", json_quote(item.name)),
        json_field("alias", serialize_optional_string_value(item.alias)),
        json_field("span", serialize_span(item.span))
    ])
