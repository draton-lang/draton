    let mut items = []
    let mut index = 0
    while index < fields.len() {
        items.push(serialize_typed_field_def(fields[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_field_def(field) {
    return json_object([
        json_field("is_mut", json_bool(field.is_mut)),
        json_field("name", json_quote(field.name)),
        json_field("ty", serialize_type(field.ty)),
        json_field("span", serialize_span(field.span))
