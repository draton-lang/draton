fn serialize_typed_extern_block(extern_block) {
    return json_object([
        json_field("abi", json_quote(extern_block.abi)),
        json_field("functions", serialize_typed_fn_defs(extern_block.functions)),
        json_field("span", serialize_span(extern_block.span))
    ])
}

fn serialize_typed_fn_defs(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_fn_def(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_type_blocks(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_type_block(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_type_block(type_block) {
    return json_object([
        json_field("members", serialize_typed_type_members(type_block.members)),
        json_field("span", serialize_span(type_block.span))
    ])
}

fn serialize_typed_type_members(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_type_member(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_type_member(member) {
    if member.function != None {
        return tagged_value("Function", serialize_typed_fn_def(member.function))
    }
    return tagged_object("Binding", [
        json_field("name", required_string(member.name)),
        json_field("ty", serialize_type_or_unit(member.ty)),
        json_field("span", serialize_span(member.span))
    ])
}

fn serialize_optional_fn_ownership_summary(summary) {
    if summary == None {
        return "null"
    }
    return serialize_fn_ownership_summary(summary)
}

fn serialize_fn_ownership_summary(summary) {
    return json_object([
        json_field("params", serialize_param_ownership_summaries(summary.params)),
        json_field("returns_owned", json_bool(summary.returns_owned))
    ])
}

fn serialize_param_ownership_summaries(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_param_ownership_summary(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_param_ownership_summary(summary) {
    return json_object([
        json_field("param_index", summary.param_index.to_string()),
        json_field("effect", serialize_use_effect(summary.effect))
    ])
}

fn serialize_typed_block(block) {
    return json_object([
        json_field("stmts", serialize_typed_stmts(block.stmts)),
        json_field("span", serialize_span(block.span))
    ])
}

fn serialize_optional_typed_block(block) {
    if block == None {
        return "null"
    }
    return serialize_typed_block(block)
}

fn serialize_typed_stmts(stmts) {
    let mut items = []
    let mut index = 0
    while index < stmts.len() {
        items.push(serialize_typed_stmt(stmts[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_stmt(stmt) {
    return json_object([
        json_field("kind", serialize_typed_stmt_kind(stmt)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_stmt_kind(stmt) {
    if stmt.kind == Let {
        return tagged_value("Let", serialize_typed_let_stmt(stmt.let_stmt))
    }
    if stmt.kind == LetDestructure {
        return tagged_value("LetDestructure", serialize_typed_let_destructure_stmt(stmt.let_destructure))
    }
    if stmt.kind == Assign {
        return tagged_value("Assign", serialize_typed_assign_stmt(stmt.assign_stmt))
    }
    if stmt.kind == Return {
        return tagged_value("Return", serialize_typed_return_stmt(stmt.return_stmt))
    }
    if stmt.kind == Expr {
        return tagged_value("Expr", serialize_typed_expr(stmt.expr))
    }
    if stmt.kind == If {
        return tagged_value("If", serialize_typed_if_stmt(stmt.if_stmt))
    }
    if stmt.kind == For {
        return tagged_value("For", serialize_typed_for_stmt(stmt.for_stmt))
    }
    if stmt.kind == While {
        return tagged_value("While", serialize_typed_while_stmt(stmt.while_stmt))
    }
    if stmt.kind == Spawn {
        return tagged_value("Spawn", serialize_typed_spawn_stmt(stmt.spawn_stmt))
    }
    if stmt.kind == Block {
        return tagged_value("Block", serialize_typed_block(stmt.block))
    }
    if stmt.kind == UnsafeBlock {
        return tagged_value("UnsafeBlock", serialize_typed_block(stmt.block))
    }
    if stmt.kind == PointerBlock {
        return tagged_value("PointerBlock", serialize_typed_block(stmt.block))
    }
    if stmt.kind == AsmBlock {
        return tagged_value("AsmBlock", json_quote(required_plain_string(stmt.asm_text)))
    }
    if stmt.kind == ComptimeBlock {
        return tagged_value("ComptimeBlock", serialize_typed_block(stmt.block))
    }
    if stmt.kind == IfCompile {
        return tagged_value("IfCompile", serialize_typed_if_compile_stmt(stmt.if_compile))
    }
    if stmt.kind == GcConfig {
        return tagged_value("GcConfig", serialize_typed_gc_config_stmt(stmt.gc_config))
    }
    return tagged_value("TypeBlock", serialize_typed_type_block(stmt.type_block))
}

fn serialize_typed_let_stmt(stmt) {
    return json_object([
        json_field("is_mut", json_bool(stmt.is_mut)),
        json_field("name", json_quote(stmt.name)),
        json_field("value", serialize_optional_typed_expr(stmt.value)),
        json_field("ty", serialize_type(stmt.ty)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_let_destructure_stmt(stmt) {
    return json_object([
        json_field("is_mut", json_bool(stmt.is_mut)),
        json_field("bindings", serialize_typed_destructure_bindings(stmt.bindings)),
        json_field("value", serialize_typed_expr(stmt.value)),
        json_field("tuple_ty", serialize_type(stmt.tuple_ty)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_destructure_bindings(bindings) {
    let mut items = []
    let mut index = 0
    while index < bindings.len() {
        items.push(serialize_typed_destructure_binding(bindings[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_destructure_binding(binding) {
    if binding.name == None {
        return json_quote("Wildcard")
    }
    return tagged_object("Name", [
        json_field("name", required_string(binding.name)),
        json_field("ty", serialize_type_or_unit(binding.ty))
    ])
}

fn serialize_typed_assign_stmt(stmt) {
    return json_object([
        json_field("target", serialize_typed_expr(stmt.target)),
        json_field("op", json_quote(stmt.op.to_string())),
        json_field("value", serialize_optional_typed_expr(stmt.value)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_return_stmt(stmt) {
    return json_object([
        json_field("value", serialize_optional_typed_expr(stmt.value)),
        json_field("ty", serialize_type(stmt.ty)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_if_stmt(stmt) {
    return json_object([
        json_field("condition", serialize_typed_expr(stmt.condition)),
        json_field("then_branch", serialize_typed_block(stmt.then_branch)),
        json_field("else_branch", serialize_optional_typed_else_branch(stmt.else_branch)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_optional_typed_else_branch(branch) {
    if branch == None {
        return "null"
    }
    return serialize_typed_else_branch(branch)
}

fn serialize_typed_else_branch(branch) {
    if branch.if_branch != None {
        return tagged_value("If", serialize_typed_if_stmt(branch.if_branch))
    }
    return tagged_value("Block", serialize_typed_block(branch.block))
}

fn serialize_typed_for_stmt(stmt) {
    return json_object([
        json_field("name", json_quote(stmt.name)),
        json_field("iter", serialize_typed_expr(stmt.iter)),
        json_field("item_type", serialize_type(stmt.item_type)),
        json_field("body", serialize_typed_block(stmt.body)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_while_stmt(stmt) {
    return json_object([
        json_field("condition", serialize_typed_expr(stmt.condition)),
        json_field("body", serialize_typed_block(stmt.body)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_spawn_stmt(stmt) {
    return json_object([
        json_field("body", serialize_typed_spawn_body(stmt.body)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_spawn_body(body) {
    if body.expr != None {
        return tagged_value("Expr", serialize_typed_expr(body.expr))
    }
    return tagged_value("Block", serialize_typed_block(body.block))
}

fn serialize_typed_if_compile_stmt(stmt) {
    return json_object([
        json_field("condition", serialize_typed_expr(stmt.condition)),
        json_field("body", serialize_typed_block(stmt.body)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_gc_config_stmt(stmt) {
    return json_object([
        json_field("entries", serialize_typed_gc_config_entries(stmt.entries)),
        json_field("span", serialize_span(stmt.span))
    ])
}

fn serialize_typed_gc_config_entries(entries) {
    let mut items = []
    let mut index = 0
    while index < entries.len() {
        items.push(serialize_typed_gc_config_entry(entries[index]))
