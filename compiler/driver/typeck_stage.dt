import { Lexer } from lexer.lexer
import { Parser } from parser.parser
import { type_check, DeprecatedSyntaxMode } from typeck.infer.result
import { serialize_lex_errors, serialize_parse_errors, serialize_parse_warnings, json_field, json_object, json_array, json_quote, json_bool, json_float, json_string_array, tagged_value, tagged_object, serialize_span } from driver.parse_stage

fn typeck_stage_json(path, strict_syntax) {
    let source = read_file(path)
    let lexer = Lexer { source: source, position: 0, line: 1, col: 1 }
    let lexed = lexer.tokenize()

    let mut parse_errors = []
    let mut parse_warnings = []
    let mut typecheck_result = "null"

    if lexed.errors.len() == 0 {
        let parser = Parser { tokens: lexed.tokens, pos: 0, errors: [], warnings: [] }
        let parsed = parser.parse()
        parse_errors = parsed.errors
        parse_warnings = parsed.warnings
        if parsed.errors.len() == 0 {
            let mut mode = Warn
            if strict_syntax {
                mode = Deny
            }
            typecheck_result = serialize_typecheck_result(type_check(parsed.program, mode))
        }
    }

    return json_object([
        json_field("lex_errors", serialize_lex_errors(lexed.errors)),
        json_field("parse_errors", serialize_parse_errors(parse_errors)),
        json_field("parse_warnings", serialize_parse_warnings(parse_warnings)),
        json_field("typecheck_result", typecheck_result)
    ])
}

fn serialize_typecheck_result(result) {
    return json_object([
        json_field("typed_program", serialize_typed_program(result.typed_program)),
        json_field("errors", serialize_type_errors(result.errors)),
        json_field("warnings", serialize_type_errors(result.warnings))
    ])
}

fn serialize_type_errors(errors) {
    let mut items = []
    let mut index = 0
    while index < errors.len() {
        items.push(serialize_type_error(errors[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_type_error(error) {
    if error.kind == Mismatch {
        return tagged_object("Mismatch", [
            json_field("expected", required_string(error.expected)),
            json_field("found", required_string(error.found)),
            json_field("hint", required_string(error.hint)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == UndefinedVar {
        return tagged_object("UndefinedVar", [
            json_field("name", required_string(error.name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == UndefinedFn {
        return tagged_object("UndefinedFn", [
            json_field("name", required_string(error.name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == NoField {
        return tagged_object("NoField", [
            json_field("field", required_string(error.field)),
            json_field("ty", required_string(error.found)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == BadBinOp {
        return tagged_object("BadBinOp", [
            json_field("op", required_string(error.name)),
            json_field("lhs", required_string(error.expected)),
            json_field("rhs", required_string(error.found)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == ArgCount {
        return tagged_object("ArgCount", [
            json_field("expected", required_int(error.expected_count)),
            json_field("got", required_int(error.got_count)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == DestructureArity {
        return tagged_object("DestructureArity", [
            json_field("pattern_len", required_int(error.pattern_len)),
            json_field("tuple_len", required_int(error.tuple_len)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == CannotInfer {
        return tagged_object("CannotInfer", [
            json_field("name", required_string(error.name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == InfiniteType {
        return tagged_object("InfiniteType", [
            json_field("var", required_string(error.name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == BadCast {
        return tagged_object("BadCast", [
            json_field("from", required_string(error.expected)),
            json_field("to", required_string(error.found)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == IncompatibleErrors {
        return tagged_object("IncompatibleErrors", [
            json_field("lhs", required_string(error.expected)),
            json_field("rhs", required_string(error.found)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == MissingInterfaceMethod {
        return tagged_object("MissingInterfaceMethod", [
            json_field("class", required_string(error.class_name)),
            json_field("interface", required_string(error.interface_name)),
            json_field("method", required_string(error.method)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == CircularInheritance {
        return tagged_object("CircularInheritance", [
            json_field("class", required_string(error.class_name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == UndefinedParent {
        return tagged_object("UndefinedParent", [
            json_field("class", required_string(error.class_name)),
            json_field("parent", required_string(error.name)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == NonExhaustiveMatch {
        return tagged_object("NonExhaustiveMatch", [
            json_field("missing", required_string(error.missing)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    if error.kind == RedundantPattern {
        return tagged_object("RedundantPattern", [
            json_field("pattern", required_string(error.pattern)),
            json_field("line", error.line.to_string()),
            json_field("col", error.col.to_string())
        ])
    }
    return tagged_object("DeprecatedSyntax", [
        json_field("syntax", required_string(error.syntax)),
        json_field("replacement", required_string(error.replacement)),
        json_field("line", error.line.to_string()),
        json_field("col", error.col.to_string())
    ])
}

fn serialize_typed_program(program) {
    return json_object([
        json_field("items", serialize_typed_items(program.items))
    ])
}

fn serialize_typed_items(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_item(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_item(item) {
    if item.kind == Fn {
        return tagged_value("Fn", serialize_typed_fn_def(item.fn_def))
    }
    if item.kind == Class {
        return tagged_value("Class", serialize_typed_class_def(item.class_def))
    }
    if item.kind == Interface {
        return tagged_value("Interface", serialize_typed_interface_def(item.interface_def))
    }
    if item.kind == Enum {
        return tagged_value("Enum", serialize_typed_enum_def(item.enum_def))
    }
    if item.kind == Error {
        return tagged_value("Error", serialize_typed_error_def(item.error_def))
    }
    if item.kind == Const {
        return tagged_value("Const", serialize_typed_const_def(item.const_def))
    }
    if item.kind == Import {
        return tagged_value("Import", serialize_typed_import_def(item.import_def))
    }
    if item.kind == Extern {
        return tagged_value("Extern", serialize_typed_extern_block(item.extern_block))
    }
    if item.kind == PanicHandler {
        return tagged_value("PanicHandler", serialize_typed_fn_def(item.fn_def))
    }
    if item.kind == OomHandler {
        return tagged_value("OomHandler", serialize_typed_fn_def(item.fn_def))
    }
    return tagged_value("TypeBlock", serialize_typed_type_block(item.type_block))
}

fn serialize_typed_fn_def(fn_def) {
    return json_object([
        json_field("is_pub", json_bool(fn_def.is_pub)),
        json_field("name", json_quote(fn_def.name)),
        json_field("params", serialize_typed_params(fn_def.params)),
        json_field("ret_type", serialize_type(fn_def.ret_type)),
        json_field("body", serialize_optional_typed_block(fn_def.body)),
        json_field("ty", serialize_type(fn_def.ty)),
        json_field("span", serialize_span(fn_def.span)),
        json_field("ownership_summary", serialize_optional_fn_ownership_summary(fn_def.ownership_summary))
    ])
}

fn serialize_typed_params(params) {
    let mut items = []
    let mut index = 0
    while index < params.len() {
        items.push(serialize_typed_param(params[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_param(param) {
    return json_object([
        json_field("name", json_quote(param.name)),
        json_field("ty", serialize_type(param.ty)),
        json_field("span", serialize_span(param.span))
    ])
}

fn serialize_typed_class_def(class_def) {
    return json_object([
        json_field("name", json_quote(class_def.name)),
        json_field("extends", serialize_optional_string_value(class_def.base_class)),
        json_field("implements", json_string_array(class_def.interfaces)),
        json_field("fields", serialize_typed_field_defs(class_def.fields)),
        json_field("methods", serialize_typed_fn_defs(class_def.methods)),
        json_field("type_blocks", serialize_typed_type_blocks(class_def.type_blocks)),
        json_field("span", serialize_span(class_def.span))
    ])
}

