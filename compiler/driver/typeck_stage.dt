fn serialize_optional_typed_expr(expr) {
    if expr == None {
        return "null"
    }
    return serialize_typed_expr(expr)
}

fn serialize_typed_exprs(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_typed_expr(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_typed_expr(expr) {
    return json_object([
        json_field("kind", serialize_typed_expr_kind(expr)),
        json_field("ty", serialize_type(expr.ty)),
        json_field("span", serialize_span(expr.span)),
        json_field("use_effect", serialize_optional_use_effect(expr.use_effect))
    ])
}

fn serialize_typed_expr_kind(expr) {
    if expr.kind == IntLit {
        return tagged_value("IntLit", required_int(expr.int_value))
    }
    if expr.kind == FloatLit {
        return tagged_value("FloatLit", json_float(required_float(expr.float_value)))
    }
    if expr.kind == StrLit {
        return tagged_value("StrLit", required_string(expr.string_value))
    }
    if expr.kind == FStrLit {
        return tagged_value("FStrLit", json_array([]))
    }
    if expr.kind == BoolLit {
        return tagged_value("BoolLit", json_bool(required_bool(expr.bool_value)))
    }
    if expr.kind == NoneLit {
        return json_quote("NoneLit")
    }
    if expr.kind == Ident {
        return tagged_value("Ident", required_string(expr.name))
    }
    if expr.kind == Array {
        return tagged_value("Array", serialize_typed_exprs(optional_exprs(expr.items)))
    }
    if expr.kind == Map {
        return tagged_value("Map", serialize_typed_map_entries(optional_map_entries(expr.entries)))
    }
    if expr.kind == Set {
        return tagged_value("Set", serialize_typed_exprs(optional_exprs(expr.items)))
    }
    if expr.kind == Tuple {
        return tagged_value("Tuple", serialize_typed_exprs(optional_exprs(expr.items)))
    }
    if expr.kind == BinOp {
        return tagged_value("BinOp", json_array([
            serialize_typed_expr(expr.left),
            required_string(expr.op),
            serialize_typed_expr(expr.right)
        ]))
    }
    if expr.kind == UnOp {
        return tagged_value("UnOp", json_array([
            required_string(expr.op),
            serialize_typed_expr(expr.body)
        ]))
    }
    if expr.kind == Call {
        return tagged_value("Call", json_array([
            serialize_typed_expr(expr.callee),
            serialize_typed_exprs(optional_exprs(expr.args))
        ]))
    }
    if expr.kind == MethodCall {
        return tagged_value("MethodCall", json_array([
            serialize_typed_expr(expr.target),
            required_string(expr.name),
            serialize_typed_exprs(optional_exprs(expr.args))
        ]))
    }
    if expr.kind == Field {
        return tagged_value("Field", json_array([
            serialize_typed_expr(expr.target),
            required_string(expr.name)
        ]))
    }
    if expr.kind == Index {
        return tagged_value("Index", json_array([
            serialize_typed_expr(expr.target),
            serialize_typed_expr(expr.index)
        ]))
    }
    if expr.kind == Lambda {
        return tagged_value("Lambda", json_array([
            serialize_typed_params(optional_params(expr.params)),
            serialize_typed_expr(expr.body)
        ]))
    }
    if expr.kind == Cast {
        return tagged_value("Cast", json_array([
            serialize_typed_expr(expr.body),
            serialize_type_or_unit(expr.cast_type)
        ]))
    }
    if expr.kind == Match {
        return tagged_value("Match", json_array([
            serialize_typed_expr(expr.left),
            serialize_typed_match_arms(optional_match_arms(expr.arms))
        ]))
    }
    if expr.kind == Ok {
        return tagged_value("Ok", serialize_typed_expr(expr.body))
    }
    if expr.kind == Err {
        return tagged_value("Err", serialize_typed_expr(expr.body))
    }
    if expr.kind == Nullish {
        return tagged_value("Nullish", json_array([
            serialize_typed_expr(expr.left),
            serialize_typed_expr(expr.right)
        ]))
    }
    return tagged_value("Chan", serialize_type_or_unit(expr.chan_type))
}

fn serialize_typed_map_entries(entries) {
    let mut items = []
    let mut index = 0
    while index < entries.len() {
        let entry = entries[index]
        items.push(json_array([
            serialize_typed_expr(entry.key),
            serialize_typed_expr(entry.value)
        ]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_match_arms(arms) {
    let mut items = []
    let mut index = 0
    while index < arms.len() {
        items.push(serialize_typed_match_arm(arms[index]))
        index = index + 1
    }
    return json_array(items)
}

fn serialize_typed_match_arm(arm) {
    return json_object([
        json_field("pattern", serialize_typed_expr(arm.pattern)),
        json_field("body", serialize_typed_match_arm_body(arm.body)),
        json_field("span", serialize_span(arm.span))
    ])
}

fn serialize_typed_match_arm_body(body) {
    if body.expr != None {
        return tagged_value("Expr", serialize_typed_expr(body.expr))
    }
    return tagged_value("Block", serialize_typed_block(body.block))
}

fn serialize_optional_use_effect(effect) {
    if effect == None {
        return "null"
    }
    return serialize_use_effect(effect)
}

fn serialize_use_effect(effect) {
    if effect == Copy {
        return json_quote("Copy")
    }
    if effect == BorrowShared {
        return json_quote("BorrowShared")
    }
    if effect == BorrowExclusive {
        return json_quote("BorrowExclusive")
    }
    return json_quote("Move")
}

fn serialize_type_or_unit(ty) {
    if ty == None {
        return json_quote("Unit")
    }
    return serialize_type(ty)
}

fn serialize_type(ty) {
    if ty.kind == Int {
        return json_quote("Int")
    }
    if ty.kind == Int8 {
        return json_quote("Int8")
    }
    if ty.kind == Int16 {
        return json_quote("Int16")
    }
    if ty.kind == Int32 {
        return json_quote("Int32")
    }
    if ty.kind == Int64 {
        return json_quote("Int64")
    }
    if ty.kind == UInt8 {
        return json_quote("UInt8")
    }
    if ty.kind == UInt16 {
        return json_quote("UInt16")
    }
    if ty.kind == UInt32 {
        return json_quote("UInt32")
    }
    if ty.kind == UInt64 {
        return json_quote("UInt64")
    }
    if ty.kind == Float {
        return json_quote("Float")
    }
    if ty.kind == Float32 {
        return json_quote("Float32")
    }
    if ty.kind == Float64 {
        return json_quote("Float64")
    }
    if ty.kind == Bool {
        return json_quote("Bool")
    }
    if ty.kind == String {
        return json_quote("String")
    }
    if ty.kind == Char {
        return json_quote("Char")
    }
    if ty.kind == Unit {
        return json_quote("Unit")
    }
    if ty.kind == Never {
        return json_quote("Never")
    }
    if ty.kind == Array {
        return tagged_value("Array", serialize_type(ty.inner))
    }
    if ty.kind == Map {
        return tagged_value("Map", json_array([
            serialize_type(ty.key),
            serialize_type(ty.value)
        ]))
    }
    if ty.kind == Set {
        return tagged_value("Set", serialize_type(ty.inner))
    }
    if ty.kind == Tuple {
        return tagged_value("Tuple", serialize_types(ty.items))
    }
    if ty.kind == Option {
        return tagged_value("Option", serialize_type(ty.inner))
    }
    if ty.kind == Result {
        return tagged_value("Result", json_array([
            serialize_type(ty.ok),
            serialize_type(ty.err)
        ]))
    }
    if ty.kind == Chan {
        return tagged_value("Chan", serialize_type(ty.inner))
    }
    if ty.kind == Fn {
        return tagged_value("Fn", json_array([
            serialize_types(ty.params),
            serialize_type(ty.ret)
        ]))
    }
    if ty.kind == Named {
        return tagged_value("Named", json_array([
            json_quote(ty.name),
            serialize_types(ty.args)
        ]))
    }
    if ty.kind == Row {
        return tagged_object("Row", [
            json_field("fields", serialize_row_fields_object(ty.fields)),
            json_field("rest", serialize_optional_type(ty.rest))
        ])
    }
    if ty.kind == Pointer {
        return tagged_value("Pointer", serialize_type(ty.inner))
    }
    return tagged_value("Var", ty.id.to_string())
}

fn serialize_optional_type(ty) {
    if ty == None {
        return "null"
    }
    return serialize_type(ty)
}

fn serialize_types(items) {
    let mut out = []
    let mut index = 0
    while index < items.len() {
        out.push(serialize_type(items[index]))
        index = index + 1
    }
    return json_array(out)
}

fn serialize_row_fields_object(fields) {
    let mut out = []
    let mut index = 0
    while index < fields.len() {
        let field = fields[index]
        out.push(json_field(field.name, serialize_type(field.ty)))
        index = index + 1
    }
    return json_object(out)
}

fn serialize_optional_string_value(value) {
    if value == None {
        return "null"
    }
    return json_quote(value)
}

fn optional_exprs(value) {
    if value == None {
        return []
    }
    return value
}

fn optional_map_entries(value) {
    if value == None {
        return []
    }
    return value
}

fn optional_params(value) {
    if value == None {
        return []
    }
    return value
}

fn optional_match_arms(value) {
    if value == None {
        return []
    }
    return value
}

fn required_string(value) {
    if value == None {
        return json_quote("")
    }
    return json_quote(value)
}

fn required_plain_string(value) {
    if value == None {
        return ""
    }
    return value
}

fn required_int(value) {
    if value == None {
        return "0"
    }
    return value.to_string()
}

fn required_float(value) {
    if value == None {
        return 0.0
    }
    return value
}

fn required_bool(value) {
    if value == None {
        return false
    }
    return value
}
