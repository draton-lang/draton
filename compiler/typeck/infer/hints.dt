fn extract_hints(checker, items) {
    let mut index = 0
    while index < items.len() {
        let item = items[index]
        if item.kind == TypeBlock && item.type_block != None {
            checker.binding_hints.push(item.type_block)
        } elif (item.kind == Fn || item.kind == PanicHandler || item.kind == OomHandler) && item.fn_def != None {
            checker.function_hints.push(item.fn_def)
        }
        index = index + 1
    }
}
