import { Scheme } from typeck.types.scheme

class EnvBinding {
    let name
    let scheme

    @type {
        name: String
        scheme: Scheme
    }
}

class EnvScope {
    let bindings

    @type {
        bindings: Array[EnvBinding]
    }
}

class TypeEnv {
    let scopes
    let fresh_counter

    @type {
        scopes: Array[EnvScope]
        fresh_counter: Int
    }
}
