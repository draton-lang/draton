import { Span } from ast.span
import { Expr } from ast.expr.expr
import { Block } from ast.stmt.stmt

enum MatchArmBodyKind {
    Expr,
    Block
}

class MatchArmBody {
    let kind
    let expr
    let block

    @type {
        kind: MatchArmBodyKind
        expr: Option[Expr]
        block: Option[Block]
    }
}

class MatchArm {
    let pattern
    let body
    let span

    @type {
        pattern: Expr
        body: MatchArmBody
        span: Span
    }
}
