import { Span } from ast.span
import { FnDef } from ast.item.fn
import { TypeBlock } from ast.item.type_block

class LayerDef {
    let name
    let methods
    let type_blocks
    let span

    @type {
        name: String
        methods: Array[FnDef]
        type_blocks: Array[TypeBlock]
        span: Span
    }
}
