import { CodeGen, LLVMValue, fat_pointer_type, new_llvm_value, cg_append_line }

@type {
    emit_upcast: (CodeGen, LLVMValue, String, String) -> LLVMValue
}

fn emit_upcast(cg, obj_ptr, class_name, iface_name) {
    let raw = str_concat("%upcast.", str_concat(class_name, str_concat(".", iface_name)))
    cg_append_line(cg, str_concat(raw, str_concat(" = upcast ", obj_ptr.raw)))
    new_llvm_value(raw, fat_pointer_type(cg), true)
}
