import { CodeGen, LLVMValue, LLVMType, Type, CodeGenError }

class ClosureEnv {
    let mut struct_type: LLVMType
    let mut capture_map: Map[String, Int]
    let mut env_ptr: LLVMValue
}

@type {
    fn build_closure_env(cg: CodeGen, captures: Array[String], capture_types: Array[Type]) -> ClosureEnv
}
