fn dump_fstr_part(part: FStrPart, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(part.kind, "Literal") {
        out = dump_append(out, dump_line(level, "Literal("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(part.text)), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Interp("))
        out = dump_append(out, dump_suffix_last(dump_expr(part.expr, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

