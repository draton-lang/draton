    let mut out = ""
    out = dump_append(out, dump_line(level, "ImportItem {"))
    out = dump_append(out, dump_field("name", dump_string(item.name), level + 1))
    out = dump_append(out, dump_field("alias", dump_option_string(item.has_alias, item.alias, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(item.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_extern_block(def: ExternBlock, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "ExternBlock {"))
    out = dump_append(out, dump_field("abi", dump_string(def.abi), level + 1))
    out = dump_append(out, dump_field("functions", dump_fndef_list(def.functions, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_type_block(def: TypeBlockDef, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "TypeBlock {"))
    out = dump_append(out, dump_field("members", dump_type_member_list(def.members, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_type_member(member: TypeMember, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(member.kind, "Binding") {
        out = dump_append(out, dump_line(level, "Binding {"))
        out = dump_append(out, dump_field("name", dump_string(member.name), level + 1))
        out = dump_append(out, dump_field("type_expr", dump_type_expr(member.type_expr, level + 1), level + 1))
        out = dump_append(out, dump_field("span", dump_span(member.span, level + 1), level + 1))
        out = dump_append(out, dump_line(level, "}"))
    } else {
        out = dump_append(out, dump_line(level, "Function("))
        out = dump_append(out, dump_suffix_last(dump_fn_def(member.def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_stmt(stmt: Stmt, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(stmt.kind, "Let") {
        out = dump_append(out, dump_line(level, "Let("))
        out = dump_append(out, dump_suffix_last(dump_let_stmt(stmt.let_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "Assign") {
        out = dump_append(out, dump_line(level, "Assign("))
        out = dump_append(out, dump_suffix_last(dump_assign_stmt(stmt.assign_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "Return") {
        out = dump_append(out, dump_line(level, "Return("))
        out = dump_append(out, dump_suffix_last(dump_return_stmt(stmt.return_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "Expr") {
        out = dump_append(out, dump_line(level, "Expr("))
        out = dump_append(out, dump_suffix_last(dump_expr(stmt.expr, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "If") {
        out = dump_append(out, dump_line(level, "If("))
        out = dump_append(out, dump_suffix_last(dump_if_stmt(stmt.if_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "For") {
        out = dump_append(out, dump_line(level, "For("))
        out = dump_append(out, dump_suffix_last(dump_for_stmt(stmt.for_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "While") {
        out = dump_append(out, dump_line(level, "While("))
        out = dump_append(out, dump_suffix_last(dump_while_stmt(stmt.while_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "Spawn") {
        out = dump_append(out, dump_line(level, "Spawn("))
        out = dump_append(out, dump_suffix_last(dump_spawn_stmt(stmt.spawn_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "Block") || str_eq_dump(stmt.kind, "UnsafeBlock") || str_eq_dump(stmt.kind, "PointerBlock") || str_eq_dump(stmt.kind, "ComptimeBlock") {
        out = dump_append(out, dump_line(level, str_concat(stmt.kind, "(")))
        out = dump_append(out, dump_suffix_last(dump_block(stmt.block, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "AsmBlock") {
        out = dump_append(out, dump_line(level, "AsmBlock("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(stmt.code)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(stmt.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "IfCompile") {
        out = dump_append(out, dump_line(level, "IfCompile("))
        out = dump_append(out, dump_suffix_last(dump_if_compile_stmt(stmt.if_compile_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(stmt.kind, "GcConfig") {
        out = dump_append(out, dump_line(level, "GcConfig("))
        out = dump_append(out, dump_suffix_last(dump_gc_config_stmt(stmt.gc_config_stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_block(block: Block, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "Block {"))
    out = dump_append(out, dump_field("stmts", dump_stmt_list(block.stmts, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(block.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_let_stmt(stmt: LetStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "LetStmt {"))
    out = dump_append(out, dump_field("is_mut", dump_bool(stmt.is_mut), level + 1))
    out = dump_append(out, dump_field("name", dump_string(stmt.name), level + 1))
    out = dump_append(out, dump_field("type_hint", dump_option_type_expr(stmt.has_type_hint, stmt.type_hint, level + 1), level + 1))
    out = dump_append(out, dump_field("value", dump_option_expr(stmt.has_value, stmt.value, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_assign_stmt(stmt: AssignStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "AssignStmt {"))
    out = dump_append(out, dump_field("target", dump_expr(stmt.target, level + 1), level + 1))
    out = dump_append(out, dump_field("op", dump_assign_op(stmt.op, level + 1), level + 1))
    out = dump_append(out, dump_field("value", dump_option_expr(stmt.has_value, stmt.value, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_return_stmt(stmt: ReturnStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "ReturnStmt {"))
    out = dump_append(out, dump_field("value", dump_option_expr(stmt.has_value, stmt.value, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_if_stmt(stmt: IfStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "IfStmt {"))
    out = dump_append(out, dump_field("condition", dump_expr(stmt.condition, level + 1), level + 1))
    out = dump_append(out, dump_field("then_branch", dump_block(stmt.then_branch, level + 1), level + 1))
    out = dump_append(out, dump_field("else_branch", dump_option_else_branch(stmt.has_else_branch, stmt.else_branch, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_for_stmt(stmt: ForStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "ForStmt {"))
    out = dump_append(out, dump_field("name", dump_string(stmt.binding), level + 1))
    out = dump_append(out, dump_field("iter", dump_expr(stmt.iter, level + 1), level + 1))
    out = dump_append(out, dump_field("body", dump_block(stmt.body, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_while_stmt(stmt: WhileStmt, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "WhileStmt {"))
    out = dump_append(out, dump_field("condition", dump_expr(stmt.condition, level + 1), level + 1))
    out = dump_append(out, dump_field("body", dump_block(stmt.body, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(stmt.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

