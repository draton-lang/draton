fn dump_match_arm(arm: MatchArm, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "MatchArm {"))
    out = dump_append(out, dump_field("pattern", dump_expr(arm.pattern, level + 1), level + 1))
    out = dump_append(out, dump_field("body", dump_match_arm_body(arm.body, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(arm.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

