    let mut out = ""
    out = dump_append(out, dump_line(level, "FieldDef {"))
    out = dump_append(out, dump_field("is_mut", dump_bool(def.is_mut), level + 1))
    out = dump_append(out, dump_field("name", dump_string(def.name), level + 1))
    out = dump_append(out, dump_field("type_hint", dump_option_type_expr(def.has_type_hint, def.type_hint, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

