import { Program, Item, FnDef, Param, ClassDef, ClassMember, LayerDef, FieldDef, InterfaceDef,
         EnumDef, ErrorDef, ConstDef, ImportDef, ImportItem, ExternBlock, TypeBlockDef,
         TypeMember, Stmt, Block, LetStmt, AssignStmt, ReturnStmt, IfStmt, ElseBranch, ForStmt,
         WhileStmt, SpawnStmt, SpawnBody, IfCompileStmt, GcConfigStmt, GcConfigEntry, Expr,
         FStrPart, MatchArm, MatchArmBody, MapEntry, TypeExpr, Span }

@type {
    fn ast_dump_program(program: Program) -> String
    fn dump_item(item: Item, level: Int) -> String
    fn dump_stmt(stmt: Stmt, level: Int) -> String
    fn dump_expr(expr: Expr, level: Int) -> String
    fn dump_type_expr(ty: TypeExpr, level: Int) -> String
    fn dump_span(span: Span, level: Int) -> String
    fn dump_indent(level: Int) -> String
    fn dump_line(level: Int, text: String) -> String
    fn dump_append(out: String, block: String) -> String
    fn dump_first_newline(text: String) -> Int
    fn dump_last_newline(text: String) -> Int
    fn dump_prefix_first(prefix: String, text: String) -> String
    fn dump_suffix_last(text: String, suffix: String) -> String
    fn dump_field(name: String, value: String, level: Int) -> String
    fn dump_bool(value: Bool) -> String
    fn dump_string(value: String) -> String
    fn dump_escape_pair(letter: String) -> String
    fn dump_string_list(values: Array[String], level: Int) -> String
    fn dump_item_list(items: Array[Item], level: Int) -> String
    fn dump_param_list(items: Array[Param], level: Int) -> String
    fn dump_class_member_list(items: Array[ClassMember], level: Int) -> String
    fn dump_fndef_list(items: Array[FnDef], level: Int) -> String
    fn dump_stmt_list(items: Array[Stmt], level: Int) -> String
    fn dump_expr_list(items: Array[Expr], level: Int) -> String
    fn dump_map_entry_list(items: Array[MapEntry], level: Int) -> String
    fn dump_fstr_part_list(items: Array[FStrPart], level: Int) -> String
    fn dump_match_arm_list(items: Array[MatchArm], level: Int) -> String
    fn dump_import_item_list(items: Array[ImportItem], level: Int) -> String
    fn dump_type_member_list(items: Array[TypeMember], level: Int) -> String
    fn dump_gc_entry_list(items: Array[GcConfigEntry], level: Int) -> String
    fn dump_type_expr_list(items: Array[TypeExpr], level: Int) -> String
    fn dump_option_string(has_value: Bool, value: String, level: Int) -> String
    fn dump_option_type_expr(has_value: Bool, value: TypeExpr, level: Int) -> String
    fn dump_option_expr(has_value: Bool, value: Expr, level: Int) -> String
    fn dump_option_block(has_value: Bool, value: Block, level: Int) -> String
    fn dump_option_else_branch(has_value: Bool, value: ElseBranch, level: Int) -> String
    fn dump_else_branch(branch: ElseBranch, level: Int) -> String
    fn dump_spawn_body(body: SpawnBody, level: Int) -> String
    fn dump_match_arm_body(body: MatchArmBody, level: Int) -> String
    fn dump_fstr_part(part: FStrPart, level: Int) -> String
    fn dump_type_member(member: TypeMember, level: Int) -> String
    fn dump_class_member(member: ClassMember, level: Int) -> String
    fn dump_bin_op(name: String, level: Int) -> String
    fn dump_un_op(name: String, level: Int) -> String
    fn dump_assign_op(name: String, level: Int) -> String
    fn str_eq_dump(a: String, b: String) -> Bool
}

fn ast_dump_program(program: Program) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(0, "Program {"))
    out = dump_append(out, dump_field("items", dump_item_list(program.items, 1), 1))
    out = dump_append(out, dump_line(0, "}"))
    out
}

fn dump_item(item: Item, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(item.kind, "Fn") {
        out = dump_append(out, dump_line(level, "Fn("))
        out = dump_append(out, dump_suffix_last(dump_fn_def(item.fn_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "PanicHandler") {
        out = dump_append(out, dump_line(level, "PanicHandler("))
        out = dump_append(out, dump_suffix_last(dump_fn_def(item.panic_handler_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "OomHandler") {
        out = dump_append(out, dump_line(level, "OomHandler("))
        out = dump_append(out, dump_suffix_last(dump_fn_def(item.oom_handler_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Class") {
        out = dump_append(out, dump_line(level, "Class("))
        out = dump_append(out, dump_suffix_last(dump_class_def(item.class_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Interface") {
        out = dump_append(out, dump_line(level, "Interface("))
        out = dump_append(out, dump_suffix_last(dump_interface_def(item.interface_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Enum") {
        out = dump_append(out, dump_line(level, "Enum("))
        out = dump_append(out, dump_suffix_last(dump_enum_def(item.enum_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Error") {
        out = dump_append(out, dump_line(level, "Error("))
        out = dump_append(out, dump_suffix_last(dump_error_def(item.error_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Const") {
        out = dump_append(out, dump_line(level, "Const("))
        out = dump_append(out, dump_suffix_last(dump_const_def(item.const_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Import") {
        out = dump_append(out, dump_line(level, "Import("))
        out = dump_append(out, dump_suffix_last(dump_import_def(item.import_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "Extern") {
        out = dump_append(out, dump_line(level, "Extern("))
        out = dump_append(out, dump_suffix_last(dump_extern_block(item.extern_block, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(item.kind, "TypeBlock") {
        out = dump_append(out, dump_line(level, "TypeBlock("))
        out = dump_append(out, dump_suffix_last(dump_type_block(item.type_block_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_fn_def(def: FnDef, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "FnDef {"))
    out = dump_append(out, dump_field("is_pub", dump_bool(def.is_pub), level + 1))
    out = dump_append(out, dump_field("name", dump_string(def.name), level + 1))
    out = dump_append(out, dump_field("params", dump_param_list(def.params, level + 1), level + 1))
    out = dump_append(out, dump_field("ret_type", dump_option_type_expr(def.has_ret_type, def.ret_type, level + 1), level + 1))
    out = dump_append(out, dump_field("body", dump_option_block(def.has_body, def.body, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_param(param: Param, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "Param {"))
    out = dump_append(out, dump_field("name", dump_string(param.name), level + 1))
    out = dump_append(out, dump_field("type_hint", dump_option_type_expr(param.has_type_hint, param.type_hint, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(param.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_class_def(def: ClassDef, level: Int) -> String {
    let mut out = ""
    let empty_type_params: Array[String] = []
    out = dump_append(out, dump_line(level, "ClassDef {"))
    out = dump_append(out, dump_field("name", dump_string(def.name), level + 1))
    out = dump_append(out, dump_field("type_params", dump_string_list(empty_type_params, level + 1), level + 1))
    out = dump_append(out, dump_field("extends", dump_option_string(def.has_extends, def.extends_name, level + 1), level + 1))
    out = dump_append(out, dump_field("implements", dump_string_list(def.implements_names, level + 1), level + 1))
    out = dump_append(out, dump_field("members", dump_class_member_list(def.members, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_class_member(member: ClassMember, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(member.kind, "Field") {
        out = dump_append(out, dump_line(level, "Field("))
        out = dump_append(out, dump_suffix_last(dump_field_def(member.field_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(member.kind, "Method") {
        out = dump_append(out, dump_line(level, "Method("))
        out = dump_append(out, dump_suffix_last(dump_fn_def(member.method_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Layer("))
        out = dump_append(out, dump_suffix_last(dump_layer_def(member.layer_def, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_layer_def(def: LayerDef, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "LayerDef {"))
    out = dump_append(out, dump_field("name", dump_string(def.name), level + 1))
    out = dump_append(out, dump_field("methods", dump_fndef_list(def.methods, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

