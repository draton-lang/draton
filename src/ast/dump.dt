    let mut out = ""
    out = dump_append(out, dump_line(level, "ImportDef {"))
    out = dump_append(out, dump_field("items", dump_import_item_list(def.items, level + 1), level + 1))
    out = dump_append(out, dump_field("span", dump_span(def.span, level + 1), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

