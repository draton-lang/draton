fn dump_import_item_list(items: Array[ImportItem], level: Int) -> String {
    if items.len() == 0 { return "[]" }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < items.len() {
        out = dump_append(out, dump_suffix_last(dump_import_item(items[i], level + 1), ","))
        i = i + 1
    }
    dump_append(out, dump_line(level, "]"))
}

fn dump_type_member_list(items: Array[TypeMember], level: Int) -> String {
    if items.len() == 0 { return "[]" }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < items.len() {
        out = dump_append(out, dump_suffix_last(dump_type_member(items[i], level + 1), ","))
        i = i + 1
    }
    dump_append(out, dump_line(level, "]"))
}

fn dump_gc_entry_list(items: Array[GcConfigEntry], level: Int) -> String {
    if items.len() == 0 { return "[]" }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < items.len() {
        out = dump_append(out, dump_suffix_last(dump_gc_entry(items[i], level + 1), ","))
        i = i + 1
    }
    dump_append(out, dump_line(level, "]"))
}

fn dump_type_expr_list(items: Array[TypeExpr], level: Int) -> String {
    if items.len() == 0 { return "[]" }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < items.len() {
        out = dump_append(out, dump_suffix_last(dump_type_expr(items[i], level + 1), ","))
        i = i + 1
    }
    dump_append(out, dump_line(level, "]"))
}

fn dump_option_string(has_value: Bool, value: String, level: Int) -> String {
    if !has_value {
        return "None"
    }
    let mut out = "Some("
    out = dump_append(out, dump_line(level + 1, dump_string(value)))
    out = dump_suffix_last(out, ",")
    dump_append(out, dump_line(level, ")"))
}

fn dump_option_type_expr(has_value: Bool, value: TypeExpr, level: Int) -> String {
    if !has_value {
        return "None"
    }
    let mut out = "Some("
    out = dump_append(out, dump_suffix_last(dump_type_expr(value, level + 1), ","))
    dump_append(out, dump_line(level, ")"))
}

fn dump_option_expr(has_value: Bool, value: Expr, level: Int) -> String {
    if !has_value {
        return "None"
    }
    let mut out = "Some("
    out = dump_append(out, dump_suffix_last(dump_expr(value, level + 1), ","))
    dump_append(out, dump_line(level, ")"))
}

fn dump_option_block(has_value: Bool, value: Block, level: Int) -> String {
    if !has_value {
        return "None"
    }
    let mut out = "Some("
    out = dump_append(out, dump_suffix_last(dump_block(value, level + 1), ","))
    dump_append(out, dump_line(level, ")"))
}

fn dump_option_else_branch(has_value: Bool, value: ElseBranch, level: Int) -> String {
    if !has_value {
        return "None"
    }
    let mut out = "Some("
    out = dump_append(out, dump_suffix_last(dump_else_branch(value, level + 1), ","))
    dump_append(out, dump_line(level, ")"))
}

fn dump_else_branch(branch: ElseBranch, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(branch.kind, "If") {
        out = dump_append(out, dump_line(level, "If("))
        out = dump_append(out, dump_suffix_last(dump_if_stmt(branch.stmt, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Block("))
        out = dump_append(out, dump_suffix_last(dump_block(branch.block, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_spawn_body(body: SpawnBody, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(body.kind, "Expr") {
        out = dump_append(out, dump_line(level, "Expr("))
        out = dump_append(out, dump_suffix_last(dump_expr(body.expr, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Block("))
        out = dump_append(out, dump_suffix_last(dump_block(body.block, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_match_arm_body(body: MatchArmBody, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(body.kind, "Expr") {
        out = dump_append(out, dump_line(level, "Expr("))
        out = dump_append(out, dump_suffix_last(dump_expr(body.expr, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Block("))
        out = dump_append(out, dump_suffix_last(dump_block(body.block, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_bin_op(name: String, level: Int) -> String {
    dump_line(level, name)
}

fn dump_un_op(name: String, level: Int) -> String {
    dump_line(level, name)
}

fn dump_assign_op(name: String, level: Int) -> String {
    dump_line(level, name)
}

fn str_eq_dump(a: String, b: String) -> Bool {
    let mut same = str_len(a) == str_len(b)
    let mut i = 0
    while same && i < str_len(a) {
        if str_byte_at(a, i) != str_byte_at(b, i) {
            same = false
        }
        i = i + 1
    }
    same
}
