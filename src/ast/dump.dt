fn dump_expr(expr: Expr, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(expr.kind, "IntLit") {
        out = dump_append(out, dump_line(level, "IntLit("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, int_to_string(expr.int_value)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "FloatLit") {
        out = dump_append(out, dump_line(level, "FloatLit("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, "0.0"), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "StrLit") {
        out = dump_append(out, dump_line(level, "StrLit("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(expr.string_value)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "FStrLit") {
        out = dump_append(out, dump_line(level, "FStrLit("))
        out = dump_append(out, dump_suffix_last(dump_fstr_part_list(expr.parts, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "BoolLit") {
        out = dump_append(out, dump_line(level, "BoolLit("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_bool(expr.bool_value)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "NoneLit") {
        out = dump_append(out, dump_line(level, "NoneLit("))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Ident") {
        out = dump_append(out, dump_line(level, "Ident("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(expr.name)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Array") {
        out = dump_append(out, dump_line(level, "Array("))
        out = dump_append(out, dump_suffix_last(dump_expr_list(expr.items, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Map") {
        out = dump_append(out, dump_line(level, "Map("))
        out = dump_append(out, dump_suffix_last(dump_map_entry_list(expr.entries, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Set") {
        out = dump_append(out, dump_line(level, "Set("))
        out = dump_append(out, dump_suffix_last(dump_expr_list(expr.items, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Tuple") {
        out = dump_append(out, dump_line(level, "Tuple("))
        out = dump_append(out, dump_suffix_last(dump_expr_list(expr.items, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "BinOp") {
        out = dump_append(out, dump_line(level, "BinOp("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.lhs, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_bin_op(expr.bin_op, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.rhs, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "UnOp") {
        out = dump_append(out, dump_line(level, "UnOp("))
        out = dump_append(out, dump_suffix_last(dump_un_op(expr.un_op, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.expr, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Call") {
        out = dump_append(out, dump_line(level, "Call("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.callee, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr_list(expr.args, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "MethodCall") {
        out = dump_append(out, dump_line(level, "MethodCall("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.target, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(expr.name)), ","))
        out = dump_append(out, dump_suffix_last(dump_expr_list(expr.args, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Field") {
        out = dump_append(out, dump_line(level, "Field("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.target, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(expr.name)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Index") {
        out = dump_append(out, dump_line(level, "Index("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.target, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.index, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Lambda") {
        out = dump_append(out, dump_line(level, "Lambda("))
        out = dump_append(out, dump_suffix_last(dump_string_list(expr.params, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.body, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Cast") {
        out = dump_append(out, dump_line(level, "Cast("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.expr, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_type_expr(expr.ty, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Match") {
        out = dump_append(out, dump_line(level, "Match("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.subject, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_match_arm_list(expr.arms, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Ok") {
        out = dump_append(out, dump_line(level, "Ok("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.expr, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Err") {
        out = dump_append(out, dump_line(level, "Err("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.expr, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Nullish") {
        out = dump_append(out, dump_line(level, "Nullish("))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.lhs, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_expr(expr.rhs, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(expr.kind, "Chan") {
        out = dump_append(out, dump_line(level, "Chan("))
        out = dump_append(out, dump_suffix_last(dump_type_expr(expr.ty, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(expr.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_type_expr(ty: TypeExpr, level: Int) -> String {
    let mut out = ""
    if str_eq_dump(ty.kind, "Named") {
        out = dump_append(out, dump_line(level, "Named("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(ty.name)), ","))
        out = dump_append(out, dump_suffix_last(dump_span(ty.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(ty.kind, "Generic") {
        out = dump_append(out, dump_line(level, "Generic("))
        out = dump_append(out, dump_suffix_last(dump_line(level + 1, dump_string(ty.name)), ","))
        out = dump_append(out, dump_suffix_last(dump_type_expr_list(ty.args, level + 1), ","))
        out = dump_append(out, dump_suffix_last(dump_span(ty.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else if str_eq_dump(ty.kind, "Pointer") {
        out = dump_append(out, dump_line(level, "Pointer("))
        out = dump_append(out, dump_suffix_last(dump_span(ty.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    } else {
        out = dump_append(out, dump_line(level, "Infer("))
        out = dump_append(out, dump_suffix_last(dump_span(ty.span, level + 1), ","))
        out = dump_append(out, dump_line(level, ")"))
    }
    out
}

fn dump_span(span: Span, level: Int) -> String {
    let mut out = ""
    out = dump_append(out, dump_line(level, "Span {"))
    out = dump_append(out, dump_field("start", int_to_string(span.start), level + 1))
    out = dump_append(out, dump_field("end", int_to_string(span.end), level + 1))
    out = dump_append(out, dump_field("line", int_to_string(span.line), level + 1))
    out = dump_append(out, dump_field("col", int_to_string(span.col), level + 1))
    out = dump_append(out, dump_line(level, "}"))
    out
}

fn dump_indent(level: Int) -> String {
    let mut out = ""
    let mut i = 0
    while i < level {
        out = str_concat(out, "    ")
        i = i + 1
    }
    out
}

fn dump_line(level: Int, text: String) -> String {
    str_concat(dump_indent(level), text)
}

fn dump_append(out: String, block: String) -> String {
    let mut next = out
    if str_len(out) == 0 {
        next = block
    } else {
        next = str_concat(str_concat(out, ascii_char(10)), block)
    }
    next
}

fn dump_first_newline(text: String) -> Int {
    let mut i = 0
    let mut idx = -1
    while idx < 0 && i < str_len(text) {
        if str_byte_at(text, i) == 10 {
            idx = i
        }
        i = i + 1
    }
    idx
}

fn dump_last_newline(text: String) -> Int {
    let mut i = 0
    let mut idx = -1
    while i < str_len(text) {
        if str_byte_at(text, i) == 10 {
            idx = i
        }
        i = i + 1
    }
    idx
}

fn dump_prefix_first(prefix: String, text: String) -> String {
    let idx = dump_first_newline(text)
    let mut out = ""
    if idx < 0 {
        out = str_concat(prefix, text)
    } else {
        let head = str_slice(text, 0, idx)
        let tail = str_slice(text, idx + 1, str_len(text))
        out = dump_append(str_concat(prefix, head), tail)
    }
    out
}

fn dump_suffix_last(text: String, suffix: String) -> String {
    let idx = dump_last_newline(text)
    let mut out = ""
    if idx < 0 {
        out = str_concat(text, suffix)
    } else {
        let head = str_slice(text, 0, idx)
        let tail = str_slice(text, idx + 1, str_len(text))
        out = dump_append(head, str_concat(tail, suffix))
    }
    out
}

fn dump_field(name: String, value: String, level: Int) -> String {
    let idx = dump_first_newline(value)
    let prefix = dump_line(level, str_concat(name, ": "))
    let mut out = ""
    if idx < 0 {
        out = str_concat(prefix, value)
    } else {
        let first = str_slice(value, 0, idx)
        let rest = str_slice(value, idx + 1, str_len(value))
        let field_indent = dump_indent(level)
        let mut trimmed_first = first
        if str_len(first) >= str_len(field_indent) && str_eq_dump(str_slice(first, 0, str_len(field_indent)), field_indent) {
            trimmed_first = str_slice(first, str_len(field_indent), str_len(first))
        }
        out = dump_append(str_concat(prefix, trimmed_first), rest)
    }
    dump_suffix_last(out, ",")
}

fn dump_bool(value: Bool) -> String {
    let mut out = "false"
    if value {
        out = "true"
    }
    out
}

fn dump_string(value: String) -> String {
    let mut out = ascii_char(34)
    let mut i = 0
    while i < str_len(value) {
        let code = str_byte_at(value, i)
        if code == 34 {
            out = str_concat(out, dump_escape_pair(ascii_char(34)))
        } else if code == 92 {
            out = str_concat(out, dump_escape_pair(ascii_char(92)))
        } else if code == 10 {
            out = str_concat(out, dump_escape_pair("n"))
        } else if code == 13 {
            out = str_concat(out, dump_escape_pair("r"))
        } else if code == 9 {
            out = str_concat(out, dump_escape_pair("t"))
        } else {
            out = str_concat(out, ascii_char(code))
        }
        i = i + 1
    }
    str_concat(out, ascii_char(34))
}

fn dump_escape_pair(letter: String) -> String {
    str_concat(ascii_char(92), letter)
}

fn dump_string_list(values: Array[String], level: Int) -> String {
    if values.len() == 0 {
        return "[]"
    }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < values.len() {
        out = dump_append(out, dump_line(level + 1, dump_string(values[i])))
        out = dump_suffix_last(out, ",")
        i = i + 1
    }
    dump_append(out, dump_line(level, "]"))
}

fn dump_item_list(items: Array[Item], level: Int) -> String {
    if items.len() == 0 { return "[]" }
    let mut out = dump_line(level, "[")
    let mut i = 0
    while i < items.len() {
        out = dump_append(out, dump_suffix_last(dump_item(items[i], level + 1), ","))
        i = i + 1
