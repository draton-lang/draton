@type {
    new_cursor: (String) -> Cursor
    cursor_len: (Cursor) -> Int
    cursor_at_end: (Cursor) -> Bool
    cursor_code_at: (Cursor, Int) -> Int
    cursor_peek_code: (Cursor) -> Int
    cursor_peek_next_code: (Cursor) -> Int
    cursor_peek_next_next_code: (Cursor) -> Int
    cursor_peek: (Cursor) -> String
    cursor_peek_next: (Cursor) -> String
    cursor_advance: (Cursor) -> String
    cursor_advance_newline: (Cursor, Int) -> Unit
    cursor_consume_if: (Cursor, Int) -> Bool
    cursor_slice: (Cursor, Int, Int) -> String
}

class Cursor {
    let mut source
    let mut pos
    let mut line
    let mut col

    @type {
        source: String
        pos: Int
        line: Int
        col: Int
    }
}

fn new_cursor(source) {
    let c = Cursor()
    c.source = source
    c.pos = 0
    c.line = 1
    c.col = 1
    c
}

fn cursor_len(c) {
    str_len(c.source)
}

fn cursor_at_end(c) {
    c.pos >= cursor_len(c)
}

fn cursor_code_at(c, index) {
    let mut code = -1
    if index < 0 || index >= cursor_len(c) {
        code = -1
    } else {
        code = str_byte_at(c.source, index)
    }
    code
}

fn cursor_peek_code(c) {
    cursor_code_at(c, c.pos)
}

fn cursor_peek_next_code(c) {
    cursor_code_at(c, c.pos + 1)
}

fn cursor_peek_next_next_code(c) {
    cursor_code_at(c, c.pos + 2)
}

fn cursor_peek(c) {
    let mut ch = ""
    if cursor_at_end(c) {
        ch = ""
    } else {
        ch = str_slice(c.source, c.pos, c.pos + 1)
    }
    ch
}

fn cursor_peek_next(c) {
    let mut ch = ""
    if c.pos + 1 >= cursor_len(c) {
        ch = ""
    } else {
        ch = str_slice(c.source, c.pos + 1, c.pos + 2)
    }
    ch
}

fn cursor_advance(c) {
    let mut ch = ""
    if cursor_at_end(c) {
        ch = ""
    } else {
        ch = str_slice(c.source, c.pos, c.pos + 1)
        c.pos = c.pos + 1
        c.col = c.col + 1
    }
    ch
}

fn cursor_advance_newline(c, bytes) {
    c.pos = c.pos + bytes
    c.line = c.line + 1
    c.col = 1
}

fn cursor_consume_if(c, expected_code) {
    let mut matched = false
    if cursor_peek_code(c) == expected_code {
        cursor_advance(c)
        matched = true
    }
    matched
}

fn cursor_slice(c, start_idx, end_idx) {
    str_slice(c.source, start_idx, end_idx)
}
