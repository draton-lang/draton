@type {
    fn new_span(start: Int, end: Int, line: Int, col: Int) -> Span
}

class Span {
    let mut start: Int
    let mut end: Int
    let mut line: Int
    let mut col: Int
}

fn new_span(start: Int, end: Int, line: Int, col: Int) {
    let span = Span()
    span.start = start
    span.end = end
    span.line = line
    span.col = col
    span
}
