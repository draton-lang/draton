@type {
    new_span: (Int, Int, Int, Int) -> Span
}

class Span {
    let mut start: Int
    let mut end: Int
    let mut line: Int
    let mut col: Int
}

fn new_span(start, end, line, col) {
    let span = Span()
    span.start = start
    span.end = end
    span.line = line
    span.col = col
    span
}
