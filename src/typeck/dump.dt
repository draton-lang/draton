    out = type_dump_append(out, type_dump_line(level, "TypedEnumDef {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.enum_name), level + 1))
    out = type_dump_append(out, type_dump_field("variants", type_dump_string_list(def.enum_variants, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.enum_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_error_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedErrorDef {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.error_name), level + 1))
    out = type_dump_append(out, type_dump_field("fields", type_dump_param_list(def.error_fields, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.error_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_const_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedConstDef {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.const_name), level + 1))
    out = type_dump_append(out, type_dump_field("value", type_dump_expr(def.const_value, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("ty", type_dump_type(def.const_ty, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.const_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_import_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedImportDef {"))
    out = type_dump_append(out, type_dump_field("module", type_dump_string_list(def.import_module, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("items", type_dump_import_item_list(def.import_items, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.import_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_extern_block(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedExternBlock {"))
    out = type_dump_append(out, type_dump_field("abi", type_dump_string(def.extern_abi), level + 1))
    out = type_dump_append(out, type_dump_field("functions", type_dump_fndef_list(def.extern_functions, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.extern_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_type_block(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedTypeBlock {"))
    out = type_dump_append(out, type_dump_field("members", type_dump_type_member_list(def.type_members, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.type_block_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_stmt(stmt, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedStmt {"))
    if str_eq_type(stmt.tag, "Let") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("Let", type_dump_let_stmt(stmt.stmt_let, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "Assign") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("Assign", type_dump_assign_stmt(stmt.stmt_assign, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "Return") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("Return", type_dump_return_stmt(stmt.stmt_return, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "Expr") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("Expr", type_dump_expr(stmt.stmt_expr, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "If") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("If", type_dump_if_stmt(stmt.stmt_if, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "For") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("For", type_dump_for_stmt(stmt.stmt_for, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "While") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("While", type_dump_while_stmt(stmt.stmt_while, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "Spawn") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("Spawn", type_dump_spawn_stmt(stmt.stmt_spawn, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "Block") || str_eq_type(stmt.tag, "UnsafeBlock") || str_eq_type(stmt.tag, "PointerBlock") || str_eq_type(stmt.tag, "ComptimeBlock") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant(stmt.tag, type_dump_block(stmt.stmt_block, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "AsmBlock") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("AsmBlock", type_dump_line(level + 2, type_dump_string(stmt.asm_code)), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "IfCompile") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("IfCompile", type_dump_if_compile(stmt.stmt_if_compile, level + 2), level + 1), level + 1))
    } else if str_eq_type(stmt.tag, "GcConfig") {
        out = type_dump_append(out, type_dump_field("kind", type_dump_variant("GcConfig", type_dump_gc_config(stmt.stmt_gc_config, level + 2), level + 1), level + 1))
    }
    out = type_dump_append(out, type_dump_field("span", type_dump_span(stmt.stmt_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_expr(expr, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedExpr {"))
    out = type_dump_append(out, type_dump_field("kind", type_dump_expr_kind(expr, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("ty", type_dump_type(expr.expr_ty, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(expr.expr_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_expr_kind(expr, level) {
    let mut out = ""
    if str_eq_type(expr.tag, "IntLit") {
        out = type_dump_append(out, type_dump_line(level, "IntLit("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, int_to_string(expr.int_value)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "FloatLit") {
        out = type_dump_append(out, type_dump_line(level, "FloatLit("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_float(expr)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "StrLit") {
        out = type_dump_append(out, type_dump_line(level, "StrLit("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_string(expr.string_value)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "BoolLit") {
        out = type_dump_append(out, type_dump_line(level, "BoolLit("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_bool(expr.bool_value)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "NoneLit") {
        out = type_dump_line(level, "NoneLit")
    } else if str_eq_type(expr.tag, "Ident") {
        out = type_dump_append(out, type_dump_line(level, "Ident("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_string(expr.ident_name)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Array") {
        out = type_dump_append(out, type_dump_line(level, "Array("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr_list(expr.expr_items, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Tuple") {
        out = type_dump_append(out, type_dump_line(level, "Tuple("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr_list(expr.expr_items, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Set") {
        out = type_dump_append(out, type_dump_line(level, "Set("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr_list(expr.expr_items, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Map") {
        out = type_dump_append(out, type_dump_line(level, "Map("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_map_entry_list(expr.map_entries, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "BinOp") {
        out = type_dump_append(out, type_dump_line(level, "BinOp("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.bin_lhs, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, expr.bin_op), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.bin_rhs, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Lambda") {
        out = type_dump_append(out, type_dump_line(level, "Lambda("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_lambda_params(expr, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.lambda_body, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Match") {
        out = type_dump_append(out, type_dump_line(level, "Match("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.match_subject, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_match_arm_list(expr.match_arms, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "Call") {
        out = type_dump_append(out, type_dump_line(level, "Call("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.call_callee, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr_list(expr.call_args, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(expr.tag, "UnOp") {
        out = type_dump_append(out, type_dump_line(level, "UnOp("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, expr.un_op), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(expr.inner_expr, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else {
        out = type_dump_line(level, expr.tag)
    }
    out
}

fn type_dump_type(ty, level) {
    let mut out = ""
    if str_eq_type(ty.type_kind, "Int") || str_eq_type(ty.type_kind, "Float") || str_eq_type(ty.type_kind, "Bool") || str_eq_type(ty.type_kind, "String") || str_eq_type(ty.type_kind, "Unit") {
        return type_dump_line(level, ty.type_kind)
    }
    if str_eq_type(ty.type_kind, "Array") || str_eq_type(ty.type_kind, "Set") || str_eq_type(ty.type_kind, "Option") || str_eq_type(ty.type_kind, "Chan") || str_eq_type(ty.type_kind, "Pointer") {
        out = type_dump_append(out, type_dump_line(level, str_concat(ty.type_kind, "(")))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type(ty.ty_inner, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    if str_eq_type(ty.type_kind, "Result") {
        out = type_dump_append(out, type_dump_line(level, "Result("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type(ty.ty_ok, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type(ty.ty_err, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    if str_eq_type(ty.type_kind, "Tuple") {
        out = type_dump_append(out, type_dump_line(level, "Tuple("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type_list(ty.ty_items, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    if str_eq_type(ty.type_kind, "Fn") {
        out = type_dump_append(out, type_dump_line(level, "Fn("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type_list(ty.ty_params, level + 1), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type(ty.ty_ret, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    if str_eq_type(ty.type_kind, "Named") {
        out = type_dump_append(out, type_dump_line(level, "Named("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_string(ty.ty_name)), ","))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type_list(ty.ty_args, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    if str_eq_type(ty.type_kind, "Var") {
        out = type_dump_append(out, type_dump_line(level, "Var("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, int_to_string(ty.ty_id)), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
        return out
    }
    type_dump_line(level, ty.type_kind)
}

