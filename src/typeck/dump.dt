import { TypedProgram, TypedItem, TypedFnDef, TypedParam, TypedClassDef, TypedFieldDef,
         TypedInterfaceDef, TypedEnumDef, TypedErrorDef, TypedConstDef, TypedImportDef,
         TypedImportItem, TypedExternBlock, TypedTypeBlockDef, TypedTypeMember, TypedBlock,
         TypedStmt, TypedLetStmt, TypedAssignStmt, TypedReturnStmt, TypedIfStmt, TypedElseBranch,
         TypedForStmt, TypedWhileStmt, TypedSpawnStmt, TypedSpawnBody, TypedIfCompileStmt,
         TypedGcConfigStmt, TypedGcConfigEntry, TypedExpr, TypedFStrPart, TypedMapEntry,
         TypedMatchArm, TypedMatchArmBody, Span, Type }

@type {
    type_dump_program: (TypedProgram) -> String
    type_dump_item: (TypedItem, Int) -> String
    type_dump_fn_def: (TypedFnDef, Int) -> String
    type_dump_param: (TypedParam, Int) -> String
    type_dump_class_def: (TypedClassDef, Int) -> String
    type_dump_interface_def: (TypedInterfaceDef, Int) -> String
    type_dump_enum_def: (TypedEnumDef, Int) -> String
    type_dump_error_def: (TypedErrorDef, Int) -> String
    type_dump_const_def: (TypedConstDef, Int) -> String
    type_dump_import_def: (TypedImportDef, Int) -> String
    type_dump_extern_block: (TypedExternBlock, Int) -> String
    type_dump_type_block: (TypedTypeBlockDef, Int) -> String
    type_dump_stmt: (TypedStmt, Int) -> String
    type_dump_block: (TypedBlock, Int) -> String
    type_dump_let_stmt: (TypedLetStmt, Int) -> String
    type_dump_assign_stmt: (TypedAssignStmt, Int) -> String
    type_dump_return_stmt: (TypedReturnStmt, Int) -> String
    type_dump_if_stmt: (TypedIfStmt, Int) -> String
    type_dump_for_stmt: (TypedForStmt, Int) -> String
    type_dump_while_stmt: (TypedWhileStmt, Int) -> String
    type_dump_spawn_stmt: (TypedSpawnStmt, Int) -> String
    type_dump_if_compile: (TypedIfCompileStmt, Int) -> String
    type_dump_gc_config: (TypedGcConfigStmt, Int) -> String
    type_dump_gc_entry: (TypedGcConfigEntry, Int) -> String
    type_dump_expr: (TypedExpr, Int) -> String
    type_dump_expr_kind: (TypedExpr, Int) -> String
    type_dump_type: (Type, Int) -> String
    type_dump_span: (Span, Int) -> String
    type_dump_indent: (Int) -> String
    type_dump_line: (Int, String) -> String
    type_dump_append: (String, String) -> String
    type_dump_first_newline: (String) -> Int
    type_dump_last_newline: (String) -> Int
    type_dump_suffix_last: (String, String) -> String
    type_dump_field: (String, String, Int) -> String
    type_dump_bool: (Bool) -> String
    type_dump_string: (String) -> String
    type_dump_item_list: (Array[TypedItem], Int) -> String
    type_dump_param_list: (Array[TypedParam], Int) -> String
    type_dump_fndef_list: (Array[TypedFnDef], Int) -> String
    type_dump_stmt_list: (Array[TypedStmt], Int) -> String
    type_dump_expr_list: (Array[TypedExpr], Int) -> String
    type_dump_type_list: (Array[Type], Int) -> String
    type_dump_string_list: (Array[String], Int) -> String
    type_dump_field_def_list: (Array[TypedFieldDef], Int) -> String
    type_dump_field_def: (TypedFieldDef, Int) -> String
    type_dump_import_item_list: (Array[TypedImportItem], Int) -> String
    type_dump_import_item: (TypedImportItem, Int) -> String
    type_dump_type_member_list: (Array[TypedTypeMember], Int) -> String
    type_dump_type_block_list: (Array[TypedTypeBlockDef], Int) -> String
    type_dump_type_member: (TypedTypeMember, Int) -> String
    type_dump_gc_entry_list: (Array[TypedGcConfigEntry], Int) -> String
    type_dump_map_entry_list: (Array[TypedMapEntry], Int) -> String
    type_dump_match_arm_list: (Array[TypedMatchArm], Int) -> String
    type_dump_match_arm: (TypedMatchArm, Int) -> String
    type_dump_match_arm_body: (TypedMatchArmBody, Int) -> String
    type_dump_lambda_params: (TypedExpr, Int) -> String
    type_dump_option_string: (Bool, String, Int) -> String
    type_dump_option_block: (Bool, TypedBlock, Int) -> String
    type_dump_option_expr: (Bool, TypedExpr, Int) -> String
    type_dump_option_else: (Bool, TypedElseBranch, Int) -> String
    type_dump_spawn_body: (TypedSpawnBody, Int) -> String
    type_dump_float: (TypedExpr) -> String
    type_dump_variant: (String, String, Int) -> String
}

fn type_dump_program(program) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(0, "TypedProgram {"))
    out = type_dump_append(out, type_dump_field("items", type_dump_item_list(program.program_items, 1), 1))
    out = type_dump_append(out, type_dump_line(0, "}"))
    out
}

fn type_dump_item(item, level) {
    let mut out = ""
    if str_eq_type(item.tag, "Fn") {
        out = type_dump_append(out, type_dump_line(level, "Fn("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_fn_def(item.item_fn_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Class") {
        out = type_dump_append(out, type_dump_line(level, "Class("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_class_def(item.item_class_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Interface") {
        out = type_dump_append(out, type_dump_line(level, "Interface("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_interface_def(item.item_interface_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Enum") {
        out = type_dump_append(out, type_dump_line(level, "Enum("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_enum_def(item.item_enum_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Error") {
        out = type_dump_append(out, type_dump_line(level, "Error("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_error_def(item.item_error_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Const") {
        out = type_dump_append(out, type_dump_line(level, "Const("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_const_def(item.item_const_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Import") {
        out = type_dump_append(out, type_dump_line(level, "Import("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_import_def(item.item_import_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "Extern") {
        out = type_dump_append(out, type_dump_line(level, "Extern("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_extern_block(item.item_extern_block, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "TypeBlock") {
        out = type_dump_append(out, type_dump_line(level, "TypeBlock("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_type_block(item.item_type_block_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "PanicHandler") {
        out = type_dump_append(out, type_dump_line(level, "PanicHandler("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_fn_def(item.item_panic_handler_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else if str_eq_type(item.tag, "OomHandler") {
        out = type_dump_append(out, type_dump_line(level, "OomHandler("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_fn_def(item.item_oom_handler_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    }
    out
}

fn type_dump_fn_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedFnDef {"))
    out = type_dump_append(out, type_dump_field("is_pub", type_dump_bool(def.fn_is_pub), level + 1))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.fn_name), level + 1))
    out = type_dump_append(out, type_dump_field("params", type_dump_param_list(def.fn_params, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("ret_type", type_dump_type(def.fn_ret_type, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("body", type_dump_option_block(def.fn_has_body, def.fn_body, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("ty", type_dump_type(def.fn_ty, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.fn_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_param(param, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedParam {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(param.param_name), level + 1))
    out = type_dump_append(out, type_dump_field("ty", type_dump_type(param.param_ty, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(param.param_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_class_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedClassDef {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.class_name), level + 1))
    out = type_dump_append(out, type_dump_field("extends", type_dump_option_string(def.class_has_extends, def.class_extends_name, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("implements", type_dump_string_list(def.class_implements_names, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("fields", type_dump_field_def_list(def.class_fields, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("methods", type_dump_fndef_list(def.class_methods, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("type_blocks", type_dump_type_block_list(def.class_type_blocks, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.class_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_interface_def(def, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedInterfaceDef {"))
    out = type_dump_append(out, type_dump_field("name", type_dump_string(def.interface_name), level + 1))
    out = type_dump_append(out, type_dump_field("methods", type_dump_fndef_list(def.interface_methods, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(def.interface_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

