fn type_dump_type_member(item, level) {
    let mut out = ""
    if str_eq_type(item.tag, "Binding") {
        out = type_dump_append(out, type_dump_line(level, "Binding {"))
        out = type_dump_append(out, type_dump_field("name", type_dump_string(item.member_name), level + 1))
        out = type_dump_append(out, type_dump_field("ty", type_dump_type(item.member_ty, level + 1), level + 1))
        out = type_dump_append(out, type_dump_field("span", type_dump_span(item.member_span, level + 1), level + 1))
        out = type_dump_append(out, type_dump_line(level, "}"))
    } else {
        out = type_dump_append(out, type_dump_line(level, "Function("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_fn_def(item.member_def, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    }
    out
}

fn type_dump_gc_entry_list(items, level) {
    if items.len() == 0 {
        return type_dump_line(level, "[]")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "["))
    let mut i = 0
    while i < items.len() {
        out = type_dump_append(out, type_dump_suffix_last(type_dump_gc_entry(items[i], level + 1), ","))
        i = i + 1
    }
    out = type_dump_append(out, type_dump_line(level, "]"))
    out
}

fn type_dump_gc_entry(item, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedGcConfigEntry {"))
    out = type_dump_append(out, type_dump_field("key", type_dump_string(item.gc_key), level + 1))
    out = type_dump_append(out, type_dump_field("value", type_dump_expr(item.gc_value, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(item.gc_entry_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_map_entry_list(items, level) {
    if items.len() == 0 {
        return type_dump_line(level, "[]")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "["))
    let mut i = 0
    while i < items.len() {
        let entry = items[i]
        let mut block = ""
        block = type_dump_append(block, type_dump_line(level + 1, "("))
        block = type_dump_append(block, type_dump_suffix_last(type_dump_expr(entry.entry_key, level + 2), ","))
        block = type_dump_append(block, type_dump_suffix_last(type_dump_expr(entry.entry_value, level + 2), ","))
        block = type_dump_append(block, type_dump_line(level + 1, ")"))
        out = type_dump_append(out, type_dump_suffix_last(block, ","))
        i = i + 1
    }
    out = type_dump_append(out, type_dump_line(level, "]"))
    out
}

fn type_dump_match_arm_list(items, level) {
    if items.len() == 0 {
        return type_dump_line(level, "[]")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "["))
    let mut i = 0
    while i < items.len() {
        out = type_dump_append(out, type_dump_suffix_last(type_dump_match_arm(items[i], level + 1), ","))
        i = i + 1
    }
    out = type_dump_append(out, type_dump_line(level, "]"))
    out
}

fn type_dump_match_arm(item, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "TypedMatchArm {"))
    out = type_dump_append(out, type_dump_field("pattern", type_dump_expr(item.arm_pattern, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("body", type_dump_match_arm_body(item.arm_body, level + 1), level + 1))
    out = type_dump_append(out, type_dump_field("span", type_dump_span(item.arm_span, level + 1), level + 1))
    out = type_dump_append(out, type_dump_line(level, "}"))
    out
}

fn type_dump_match_arm_body(body, level) {
    let mut out = ""
    if str_eq_type(body.tag, "Expr") {
        out = type_dump_append(out, type_dump_line(level, "Expr("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(body.body_expr, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else {
        out = type_dump_append(out, type_dump_line(level, "Block("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_block(body.body_block, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    }
    out
}

fn type_dump_lambda_params(expr, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "["))
    let mut i = 0
    while i < expr.lambda_params.len() {
        let param = TypedParam()
        param.param_name = expr.lambda_params[i]
        if str_eq_type(expr.expr_ty.type_kind, "Fn") && i < expr.expr_ty.ty_params.len() {
            param.param_ty = expr.expr_ty.ty_params[i]
        } else {
            param.param_ty = type_unit()
        }
        param.param_span = expr.expr_span
        out = type_dump_append(out, type_dump_suffix_last(type_dump_param(param, level + 1), ","))
        i = i + 1
    }
    out = type_dump_append(out, type_dump_line(level, "]"))
    out
}

fn type_dump_option_string(has_value, value, level) {
    if !has_value {
        return type_dump_line(level, "None")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "Some("))
    out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, type_dump_string(value)), ","))
    out = type_dump_append(out, type_dump_line(level, ")"))
    out
}

fn type_dump_option_block(has_value, value, level) {
    if !has_value {
        return type_dump_line(level, "None")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "Some("))
    out = type_dump_append(out, type_dump_suffix_last(type_dump_block(value, level + 1), ","))
    out = type_dump_append(out, type_dump_line(level, ")"))
    out
}

fn type_dump_option_expr(has_value, value, level) {
    if !has_value {
        return type_dump_line(level, "None")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "Some("))
    out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(value, level + 1), ","))
    out = type_dump_append(out, type_dump_line(level, ")"))
    out
}

fn type_dump_option_else(has_value, value, level) {
    if !has_value {
        return type_dump_line(level, "None")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "Some("))
    if str_eq_type(value.tag, "If") {
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, "If("), ""))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_if_stmt(value.else_if_stmt, level + 2), ","))
        out = type_dump_append(out, type_dump_line(level + 1, ")"))
    } else {
        out = type_dump_append(out, type_dump_suffix_last(type_dump_line(level + 1, "Block("), ""))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_block(value.else_block, level + 2), ","))
        out = type_dump_append(out, type_dump_line(level + 1, ")"))
    }
    out = type_dump_append(out, type_dump_line(level, ")"))
    out
}

fn type_dump_spawn_body(value, level) {
    let mut out = ""
    if str_eq_type(value.tag, "Expr") {
        out = type_dump_append(out, type_dump_line(level, "Expr("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_expr(value.spawn_expr, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    } else {
        out = type_dump_append(out, type_dump_line(level, "Block("))
        out = type_dump_append(out, type_dump_suffix_last(type_dump_block(value.spawn_block, level + 1), ","))
        out = type_dump_append(out, type_dump_line(level, ")"))
    }
    out
}
