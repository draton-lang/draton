fn type_dump_indent(level) {
    let mut out = ""
    let mut i = 0
    while i < level {
        out = str_concat(out, "    ")
        i = i + 1
    }
    out
}

fn type_dump_line(level, text) {
    str_concat(type_dump_indent(level), text)
}

fn type_dump_append(out, block) {
    if str_len(out) == 0 {
        return block
    }
    str_concat(str_concat(out, ascii_char(10)), block)
}

fn type_dump_first_newline(text) {
    let mut idx = -1
    let mut i = 0
    while idx < 0 && i < str_len(text) {
        if str_byte_at(text, i) == 10 {
            idx = i
        }
        i = i + 1
    }
    idx
}

fn type_dump_last_newline(text) {
    let mut idx = -1
    let mut i = 0
    while i < str_len(text) {
        if str_byte_at(text, i) == 10 {
            idx = i
        }
        i = i + 1
    }
    idx
}

fn type_dump_suffix_last(text, suffix) {
    let idx = type_dump_last_newline(text)
    if idx < 0 {
        return str_concat(text, suffix)
    }
    let head = str_slice(text, 0, idx + 1)
    let tail = str_slice(text, idx + 1, str_len(text))
    str_concat(head, str_concat(tail, suffix))
}

fn type_dump_field(name, value, level) {
    let prefix = type_dump_line(level, str_concat(name, ": "))
    let idx = type_dump_first_newline(value)
    let indent = type_dump_indent(level)
    let mut trim = str_len(value) >= str_len(indent)
    let mut i = 0
    while trim && i < str_len(indent) {
        if str_byte_at(value, i) != str_byte_at(indent, i) {
            trim = false
        }
        i = i + 1
    }
    let mut single = value
    if trim {
        single = str_slice(value, str_len(indent), str_len(value))
    }
    if idx < 0 {
        return str_concat(str_concat(prefix, single), ",")
    }
    let raw_first = str_slice(value, 0, idx)
    trim = str_len(raw_first) >= str_len(indent)
    i = 0
    while trim && i < str_len(indent) {
        if str_byte_at(raw_first, i) != str_byte_at(indent, i) {
            trim = false
        }
        i = i + 1
    }
    let mut first = raw_first
    if trim {
        first = str_slice(raw_first, str_len(indent), str_len(raw_first))
    }
    let rest = str_slice(value, idx + 1, str_len(value))
    let mut out = str_concat(prefix, first)
    out = type_dump_append(out, rest)
    str_concat(out, ",")
}

fn type_dump_variant(name, value, level) {
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, str_concat(name, "(")))
    out = type_dump_append(out, type_dump_suffix_last(value, ","))
    out = type_dump_append(out, type_dump_line(level, ")"))
    out
}

fn type_dump_bool(value) {
    if value { return "true" }
    "false"
}

fn type_dump_float(expr) {
    let _unused = expr.float_value
    "0.0"
}

fn type_dump_string(value) {
    let mut out = ascii_char(34)
    let mut i = 0
    while i < str_len(value) {
        let code = str_byte_at(value, i)
        if code == 34 {
            out = str_concat(out, "\\\"")
        } else if code == 92 {
            out = str_concat(out, "\\\\")
        } else if code == 10 {
            out = str_concat(out, "\\n")
        } else if code == 13 {
            out = str_concat(out, "\\r")
        } else if code == 9 {
            out = str_concat(out, "\\t")
        } else {
            out = str_concat(out, ascii_char(code))
        }
        i = i + 1
    }
    str_concat(out, ascii_char(34))
}

fn type_dump_item_list(items, level) {
    if items.len() == 0 {
        return type_dump_line(level, "[]")
    }
    let mut out = ""
    out = type_dump_append(out, type_dump_line(level, "["))
    let mut i = 0
    while i < items.len() {
        out = type_dump_append(out, type_dump_suffix_last(type_dump_item(items[i], level + 1), ","))
        i = i + 1
    }
    out = type_dump_append(out, type_dump_line(level, "]"))
    out
}

