class TypedProgram {
    let mut program_items

    @type {
        program_items: Array[TypedItem]
    }
}

@type {
    empty_typed_program: () -> TypedProgram
}

fn empty_typed_program() {
    @type {
        items: Array[TypedItem]
    }
    let program = TypedProgram()
    let items = []
    program.program_items = items
    program
}
