/// Test helper module used by `drat test`.

@type {
    fn __draton_std_test_case(name: String, body: () -> Unit)
    fn __draton_std_test_eq[T](a: T, b: T)
    fn __draton_std_test_neq[T](a: T, b: T)
    fn __draton_std_test_ok[T, E](r: Result[T, E])
    fn __draton_std_test_err[T, E](r: Result[T, E])
    fn __draton_std_test_true(b: Bool)
    fn __draton_std_test_false(b: Bool)
    fn __draton_std_test_panic_with(msg: String)
    fn __draton_std_test_skip(reason: String)
    fn case(name: String, body: () -> Unit)
    fn eq[T](a: T, b: T)
    fn neq[T](a: T, b: T)
    fn ok[T, E](r: Result[T, E])
    fn err[T, E](r: Result[T, E])
    fn true_(b: Bool)
    fn false_(b: Bool)
    fn panic_with(msg: String)
    fn skip(reason: String)
}

@extern "C" {
    fn __draton_std_test_case(name, body)
    fn __draton_std_test_eq[T](a, b)
    fn __draton_std_test_neq[T](a, b)
    fn __draton_std_test_ok[T, E](r)
    fn __draton_std_test_err[T, E](r)
    fn __draton_std_test_true(b)
    fn __draton_std_test_false(b)
    fn __draton_std_test_panic_with(msg)
    fn __draton_std_test_skip(reason)
}

/// Registers a named test case.
pub fn case(name, body) { return __draton_std_test_case(name, body) }

/// Asserts equality.
pub fn eq[T](a, b) { return __draton_std_test_eq(a, b) }

/// Asserts inequality.
pub fn neq[T](a, b) { return __draton_std_test_neq(a, b) }

/// Asserts a result is `Ok`.
pub fn ok[T, E](r) { return __draton_std_test_ok(r) }

/// Asserts a result is `Err`.
pub fn err[T, E](r) { return __draton_std_test_err(r) }

/// Asserts a boolean is true.
pub fn true_(b) { return __draton_std_test_true(b) }

/// Asserts a boolean is false.
pub fn false_(b) { return __draton_std_test_false(b) }

/// Asserts a panic containing a message.
pub fn panic_with(msg) { return __draton_std_test_panic_with(msg) }

/// Skips a test.
pub fn skip(reason) { return __draton_std_test_skip(reason) }
