// GC stress: alloc array literals lớn nhiều lần
@type {
    main: () -> Int
}

fn main() {
    let mut i = 0
    let mut s = 0
    while (i < 5000) {
        let xs = [
            i, i + 1, i + 2, i + 3, i + 4, i + 5, i + 6, i + 7,
            i + 8, i + 9, i + 10, i + 11, i + 12, i + 13, i + 14, i + 15,
        ]
        s += i
        i++
    }
    s % 100
}
