// RUN: compile
class User {
    let name

    layer Access {
        fn getName() {
            return self.name
        }
    }

    layer Reader {
        fn read() {
            return self.getName()
        }
    }

    @type {
        name: String
        getName: () -> String
        read: () -> String
    }
}

@type {
    main: (User) -> String
}

fn main(u) {
    return u.read()
}
