// RUN: compile
class Counter {
    let value

    layer Access {
        fn current() {
            return self.value
        }

        fn read() {
            return self.current()
        }
    }

    @type {
        value: Int
        current: () -> Int
        read: () -> Int
    }
}

@type {
    main: (Counter) -> Int
}

fn main(c) {
    return c.read()
}
