// RUN: compile
class Animal {
    layer Voice {
        fn speak() {
            return 1
        }
    }

    @type {
        speak: () -> Int
    }
}
class Dog extends Animal {
    layer Voice {
        fn bark() {
            return 2
        }
    }

    @type {
        bark: () -> Int
    }
}

@type {
    main: (Dog) -> Int
}

fn main(d) {
    return d.speak()
}
