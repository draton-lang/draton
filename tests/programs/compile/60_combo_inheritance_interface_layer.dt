// RUN: compile
interface Named {
    @type {
        name: () -> String
    }

    fn name()
}
class Entity {
    let label

    layer Identity {
        fn name() {
            return self.label
        }
    }

    @type {
        label: String
        name: () -> String
    }
}
class User extends Entity implements Named {
    layer Identity {
        fn name() {
            return self.label
        }
    }

    layer Access {
        fn read() {
            return self.name()
        }
    }

    @type {
        name: () -> String
        read: () -> String
    }
}

@type {
    render: (Named) -> String
    main: (User) -> String
}

fn render(n) {
    return n.name()
}

fn main(u) {
    return render(u)
}
