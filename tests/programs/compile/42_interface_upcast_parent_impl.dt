// RUN: compile
interface Drawable {
    fn draw()
    @type {
        draw: () -> Int
    }
}
class Shape {
    @type {
        id: () -> Int
    }
    fn id() { return 7 }
}
class Circle extends Shape implements Drawable {
    @type {
        draw: () -> Int
    }
    fn draw() { return self.id() }
}
@type {
    render: (Drawable) -> Int
    main: (Circle) -> Int
}
fn render(d) { return d.draw() }
fn main(c) { return render(c) }
